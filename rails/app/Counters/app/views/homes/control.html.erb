<% content_for :title, "管理画面" %>
<style>
  body { font-family: sans-serif; max-width: 800px; margin: 2rem auto; padding: 0 1rem; }
  h1, h2 { border-bottom: 1px solid #ddd; padding-bottom: 0.4rem; }
  table { width: 100%; border-collapse: collapse; margin-top: 1rem; }
  th, td { text-align: left; padding: 0.5rem 0.75rem; border: 1px solid #ddd; }
  th { background: #f5f5f5; }
  .url { font-family: monospace; font-size: 0.85rem; color: #555; }
  .btn { padding: 0.3rem 0.7rem; border: none; border-radius: 4px; cursor: pointer; font-size: 0.85rem; }
  .btn-danger { background: #dc3545; color: #fff; }
  .btn-danger:hover { background: #b02a37; }
  .btn-add { background: #0d6efd; color: #fff; }
  .btn-add:hover { background: #0a58ca; }
  .alert { padding: 0.75rem 1rem; border-radius: 4px; margin-bottom: 1rem; }
  .alert-notice { background: #d1e7dd; color: #0f5132; }
  .alert-alert  { background: #f8d7da; color: #842029; }
  form.inline { display: inline; }
  .tabs { display: flex; border-bottom: 2px solid #ddd; margin-bottom: 1.5rem; gap: 0; }
  .tab-btn { padding: 0.5rem 1.2rem; background: none; border: 1px solid transparent; border-bottom: none; border-radius: 4px 4px 0 0; cursor: pointer; font-size: 1rem; color: #555; margin-bottom: -2px; }
  .tab-btn.active { background: #fff; border-color: #ddd; color: #000; font-weight: bold; }
  .tab-content { display: none; }
  .tab-content.active { display: block; }
  .summary-number { font-size: 2rem; font-weight: bold; }
  .summary-table td:last-child { font-weight: bold; }
</style>

<h1>管理画面</h1>

<% if flash[:notice] %>
  <div class="alert alert-notice"><%= flash[:notice] %></div>
<% end %>
<% if flash[:alert] %>
  <div class="alert alert-alert"><%= flash[:alert] %></div>
<% end %>

<div class="tabs">
  <button class="tab-btn active" onclick="switchTab('tab-total', this)">合計</button>
  <button class="tab-btn" onclick="switchTab('tab-individual', this)">個別集計</button>
  <button class="tab-btn" onclick="switchTab('tab-time', this)">時間別集計</button>
</div>

<div id="tab-total" class="tab-content active">
  <h2>合計アクセス数</h2>
  <p class="summary-number"><%= @total %> 件</p>
  <table class="summary-table" style="width: auto; min-width: 300px;">
    <thead>
      <tr><th>種別</th><th>カウント</th></tr>
    </thead>
    <tbody>
      <tr><td>登録済み名前</td><td><%= @registered_total %></td></tr>
      <tr><td>未登録・名前なし</td><td><%= @unregistered_total %></td></tr>
    </tbody>
  </table>
</div>

<div id="tab-individual" class="tab-content">
  <h2>名前を追加</h2>
  <%= form_with url: redirect_control_names_path, method: :post do |f| %>
    <%= f.text_field :name, placeholder: "例: campaign_a", style: "padding:0.4rem; width:200px;" %>
    <%= f.submit "追加", class: "btn btn-add" %>
  <% end %>

  <h2>個別集計（合計: <%= @total %> 件）</h2>
  <table>
    <thead>
      <tr>
        <th>名前</th>
        <th>カウント</th>
        <th>リダイレクトURL</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% @counts.each do |name, count| %>
        <tr>
          <td><%= name %></td>
          <td><%= count %></td>
          <td class="url">
            <% unless name == Counter::UNNAMED %>
              <%= "#{@redirect_base}?name=#{ERB::Util.url_encode(name)}" %>
            <% end %>
          </td>
          <td>
            <%= form_with url: redirect_control_counters_path, method: :delete, class: "inline" do |f| %>
              <%= f.hidden_field :name, value: name %>
              <%= f.submit "カウントリセット", class: "btn btn-danger",
                  data: { turbo_confirm: "「#{name}」のカウントをリセットしますか？" } %>
            <% end %>
            <% if @tracked_names.include?(name) %>
              &nbsp;
              <%= form_with url: redirect_control_name_path(name: name), method: :delete, class: "inline" do |f| %>
                <%= f.submit "名前削除", class: "btn btn-danger",
                    data: { turbo_confirm: "「#{name}」を管理リストから削除しますか？" } %>
              <% end %>
            <% end %>
          </td>
        </tr>
      <% end %>
      <% if @counts.empty? %>
        <tr><td colspan="4" style="text-align:center; color:#888;">まだデータがありません</td></tr>
      <% end %>
    </tbody>
  </table>

  <div style="margin-top: 2rem;">
    <%= form_with url: redirect_control_counters_path, method: :delete do |f| %>
      <%= f.submit "全カウントをリセット", class: "btn btn-danger",
          data: { turbo_confirm: "全てのカウントをリセットしますか？" } %>
    <% end %>
  </div>
</div>

<div id="tab-time" class="tab-content">
  <h2>時間別集計</h2>
  <% if @time_slots.empty? %>
    <p style="color:#888;">まだデータがありません</p>
  <% else %>
    <div style="overflow-x: auto;">
      <table>
        <thead>
          <tr>
            <th>日時</th>
            <% @counts.keys.each do |name| %>
              <th><%= name %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% @time_slots.each do |slot| %>
            <tr>
              <td style="white-space:nowrap;"><%= "#{slot[0]} #{slot[1].to_s.rjust(2, '0')}:00" %></td>
              <% @counts.keys.each do |name| %>
                <td><%= @time_stats[slot][name] || 0 %></td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>

<script>
  function switchTab(id, btn) {
    document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));
    document.getElementById(id).classList.add('active');
    btn.classList.add('active');
  }
</script>
